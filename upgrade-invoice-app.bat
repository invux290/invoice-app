@echo off
chcp 65001 >nul
echo.
echo =====================================================
echo   InvoiceKit - Full Upgrade Script
echo =====================================================
echo.

if not exist "server.js" (
    echo [ERROR] Run this script from your project root folder
    pause
    exit /b 1
)
if not exist "public\index.html" (
    echo [ERROR] public\index.html not found
    pause
    exit /b 1
)
echo [OK] Project folder confirmed.
echo.

:: Write temp PowerShell script
echo $s = @() > "%TEMP%\ik_upgrade.ps1"
echo $s += '' >> "%TEMP%\ik_upgrade.ps1"
echo $s += '' >> "%TEMP%\ik_upgrade.ps1"
echo $s += '' >> "%TEMP%\ik_upgrade.ps1"
echo $s += '' >> "%TEMP%\ik_upgrade.ps1"
echo $b = [Convert]::FromBase64String($s -join '') >> "%TEMP%\ik_upgrade.ps1"
echo [IO.File]::WriteAllBytes((Join-Path (Get-Location) 'server.js'), $b) >> "%TEMP%\ik_upgrade.ps1"
echo Write-Host '[OK] server.js written.' >> "%TEMP%\ik_upgrade.ps1"

echo $h = @() >> "%TEMP%\ik_upgrade.ps1"
echo $h += '' >> "%TEMP%\ik_upgrade.ps1"
echo $h += '' >> "%TEMP%\ik_upgrade.ps1"
echo $h += '' >> "%TEMP%\ik_upgrade.ps1"
echo $h += '' >> "%TEMP%\ik_upgrade.ps1"
echo $h += '' >> "%TEMP%\ik_upgrade.ps1"
echo $h += '' >> "%TEMP%\ik_upgrade.ps1"
echo $h += '' >> "%TEMP%\ik_upgrade.ps1"
echo $h += '' >> "%TEMP%\ik_upgrade.ps1"
echo $h += '' >> "%TEMP%\ik_upgrade.ps1"
echo $h += '' >> "%TEMP%\ik_upgrade.ps1"
echo $h += '' >> "%TEMP%\ik_upgrade.ps1"
echo $h += '' >> "%TEMP%\ik_upgrade.ps1"
echo $h += '' >> "%TEMP%\ik_upgrade.ps1"
echo $h += '' >> "%TEMP%\ik_upgrade.ps1"
echo $b2 = [Convert]::FromBase64String($h -join '') >> "%TEMP%\ik_upgrade.ps1"
echo [IO.File]::WriteAllBytes((Join-Path (Get-Location) 'public\index.html'), $b2) >> "%TEMP%\ik_upgrade.ps1"
echo Write-Host '[OK] public\index.html written.' >> "%TEMP%\ik_upgrade.ps1"

echo [STEP 1-2/4] Writing server.js and index.html ...
powershell -NoProfile -ExecutionPolicy Bypass -File "%TEMP%\ik_upgrade.ps1"
if %errorlevel% neq 0 (
    echo [ERROR] File write failed
    pause
    exit /b 1
)
del "%TEMP%\ik_upgrade.ps1"
echo.

echo [STEP 3/4] Running npm install ...
call npm install
if %errorlevel% neq 0 (
    echo [ERROR] npm install failed
    pause
    exit /b 1
)
echo.

echo [STEP 4/4] Committing and pushing to GitHub ...
git add .
git commit -m "upgrade invoice system"
git push
if %errorlevel% neq 0 (
    echo [WARN] git push failed - check git remote -v
    pause
    exit /b 1
)

echo.
echo =====================================================
echo   DONE - site will redeploy on Render
echo =====================================================
echo.