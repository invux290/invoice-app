@echo off
chcp 65001 >nul
echo.
echo =====================================================
echo   InvoiceKit - Add Landing Page
echo =====================================================
echo.
if not exist "server.js" (
    echo [ERROR] Run this from your project root folder
    pause & exit /b 1
)
echo [OK] Project folder confirmed.
echo.
:: Write PowerShell script to temp file
echo $a = @() > "%TEMP%\ik_landing.ps1"
echo $a += '' >> "%TEMP%\ik_landing.ps1"
