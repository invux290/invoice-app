echo $c += '' >> "%TEMP%\ik_landing.ps1"
echo $c += '' >> "%TEMP%\ik_landing.ps1"
echo $d=[Convert]::FromBase64String($c -join '') >> "%TEMP%\ik_landing.ps1"
echo [IO.File]::WriteAllBytes((Join-Path (Get-Location) 'public\app.html'),$d) >> "%TEMP%\ik_landing.ps1"
echo Write-Host '[OK] Invoice app written to public\app.html' >> "%TEMP%\ik_landing.ps1"

echo [STEP 1/3] Writing landing page and app files ...
powershell -NoProfile -ExecutionPolicy Bypass -File "%TEMP%\ik_landing.ps1"
if %errorlevel% neq 0 ( echo [ERROR] File write failed & pause & exit /b 1 )
del "%TEMP%\ik_landing.ps1"
echo.

echo [STEP 2/3] Running npm install ...
call npm install
echo.

echo [STEP 3/3] Committing and pushing to GitHub ...
git add .
git commit -m "add landing page"
git push
if %errorlevel% neq 0 ( echo [WARN] git push failed & pause & exit /b 1 )

echo.
