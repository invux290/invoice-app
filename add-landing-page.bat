echo $a += '' >> "%TEMP%\ik_landing.ps1"
echo $a += '' >> "%TEMP%\ik_landing.ps1"
echo $a += '' >> "%TEMP%\ik_landing.ps1"
echo $a += '' >> "%TEMP%\ik_landing.ps1"
echo $a += '' >> "%TEMP%\ik_landing.ps1"
echo $a += '' >> "%TEMP%\ik_landing.ps1"
echo $b=[Convert]::FromBase64String($a -join '') >> "%TEMP%\ik_landing.ps1"
echo [IO.File]::WriteAllBytes((Join-Path (Get-Location) 'public\index.html'),$b) >> "%TEMP%\ik_landing.ps1"
echo Write-Host '[OK] Landing page written to public\index.html' >> "%TEMP%\ik_landing.ps1"
echo $c = @() >> "%TEMP%\ik_landing.ps1"
